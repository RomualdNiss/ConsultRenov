---
import Icon from "./Icon.astro";

interface Props {
  title: string;
  copy: string;
}

const { title, copy } = Astro.props;
---

<article class="benefit-card">
  <div class="icon-wrap">
    <Icon name="check" />
  </div>
  <h3 class="title-md">{title}</h3>
  <p class="text-muted">{copy}</p>
</article>
