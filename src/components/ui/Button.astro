---
interface Props {
  [key: string]: unknown;
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "default" | "small";
  type?: "button" | "submit";
  target?: string;
  rel?: string;
  className?: string;
}

const {
  href,
  variant = "primary",
  size = "default",
  type = "button",
  target,
  rel,
  className = "",
  ...attributes
} = Astro.props;

const classes = [
  "button",
  variant === "primary" ? "button-primary" : "",
  variant === "secondary" ? "button-secondary" : "",
  variant === "ghost" ? "button-ghost" : "",
  size === "small" ? "button-small" : "",
  className,
]
  .filter(Boolean)
  .join(" ");
---

{href ? (
  <a class={classes} href={href} target={target} rel={rel} {...attributes}>
    <span class="button-text"><slot /></span>
  </a>
) : (
  <button class={classes} type={type} {...attributes}>
    <span class="button-text"><slot /></span>
  </button>
)}
