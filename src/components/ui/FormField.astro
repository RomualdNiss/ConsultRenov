---
interface Props {
  label: string;
  name: string;
  type?:
    | "text"
    | "email"
    | "tel"
    | "url"
    | "number"
    | "search"
    | "password";
  required?: boolean;
  placeholder?: string;
  textarea?: boolean;
  full?: boolean;
}

const {
  label,
  name,
  type = "text",
  required = false,
  placeholder = "",
  textarea = false,
  full = false,
} = Astro.props;

const classes = full ? "form-field is-full" : "form-field";
const inputPlaceholder = placeholder || " ";
---

<div class={classes}>
  <div class="field-control">
    {textarea ? (
      <textarea
        id={name}
        name={name}
        placeholder={inputPlaceholder}
        required={required}
        data-cursor-text
      ></textarea>
    ) : (
      <input
        id={name}
        name={name}
        type={type}
        placeholder={inputPlaceholder}
        required={required}
        data-cursor-text
      />
    )}
    <label class="field-label" for={name}>{label}</label>
    <span class="field-line" aria-hidden="true"></span>
  </div>
</div>
