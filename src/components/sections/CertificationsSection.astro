---
import { commitments } from "../../data/reassurance";
import SectionHeading from "../ui/SectionHeading.astro";
import Icon from "../ui/Icon.astro";
---

<section class="section">
  <div class="container">
    <SectionHeading
      eyebrow="Engagements"
      title="Des repères de confiance à chaque étape du projet"
      copy="ConsultRenov met l'accent sur la qualité des matériaux, l'accompagnement personnalisé et le sérieux du suivi tout au long du projet."
    />
    <div class="cards-grid">
      {commitments.map((item) => (
        <article class="benefit-card" data-reveal>
          <div class="icon-wrap">
            <Icon name="shield" />
          </div>
          <h3 class="title-md">{item.title}</h3>
          <p class="text-muted">{item.copy}</p>
        </article>
      ))}
    </div>
  </div>
</section>
