---
import { benefits } from "../../data/reassurance";
import BenefitCard from "../ui/BenefitCard.astro";
import SectionHeading from "../ui/SectionHeading.astro";
---

<section class="section surface" style="border-radius: 0; border-inline: 0;">
  <div class="container">
    <SectionHeading
      eyebrow="Pourquoi choisir ConsultRenov"
      title="Une rénovation orientée bénéfices concrets pour le client"
      copy="Des projets pensés pour votre confort, vos usages quotidiens et la valorisation durable de votre maison."
    />
    <div class="cards-grid">
      {benefits.map((item) => (
        <div data-reveal>
          <BenefitCard title={item.title} copy={item.copy} />
        </div>
      ))}
    </div>
  </div>
</section>
