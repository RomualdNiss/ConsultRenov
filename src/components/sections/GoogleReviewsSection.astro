---
import { reviewsConfig } from "../../config/site";
import Button from "../ui/Button.astro";
import SectionHeading from "../ui/SectionHeading.astro";

const hasWidget = Boolean(reviewsConfig.widgetHtml.trim());
const hasBusinessUrl = Boolean(reviewsConfig.googleBusinessUrl.trim());
---

{
  reviewsConfig.enabled && (
    <section class="section surface" style="border-radius: 0; border-inline: 0;">
      <div class="container reviews-grid">
        <div data-reveal="left">
          <SectionHeading
            eyebrow="Avis clients"
            title={reviewsConfig.widgetTitle}
            copy={reviewsConfig.widgetIntro}
          />

          <div class="reviews-stats">
            <div class="reviews-stat">
              <strong>{reviewsConfig.reviewCount}</strong>
              <span>{reviewsConfig.reviewCountLabel}</span>
            </div>
            <div class="reviews-stat">
              <strong>Présence locale</strong>
              <span>un repère rassurant avant la prise de contact</span>
            </div>
            <div class="reviews-stat">
              <strong>Preuve sociale</strong>
              <span>de vrais retours consultables sur Google</span>
            </div>
          </div>

          {hasBusinessUrl && (
            <div class="cluster" style="margin-top: 1.5rem;">
              <Button
                href={reviewsConfig.googleBusinessUrl}
                variant="primary"
                target="_blank"
                rel="noreferrer"
              >
                Voir sur Google
              </Button>
            </div>
          )}
        </div>

        <div class="reviews-widget-shell" data-reveal="right">
          {hasWidget ? (
            <div class="reviews-widget" set:html={reviewsConfig.widgetHtml} />
          ) : (
            <div class="reviews-widget-fallback">
              <h3 class="title-md">Une présence Google qui rassure dès la première visite</h3>
              <p class="text-muted">
                Les avis publiés sur Google renforcent la crédibilité de l'entreprise et permettent
                aux futurs clients de se projeter avant même la première prise de contact.
              </p>
              <div class="reviews-proof">
                <strong>{reviewsConfig.reviewCount}</strong>
                <span>{reviewsConfig.reviewCountLabel}</span>
              </div>
              <ul class="bullet-list stack" style="margin-top: 1rem;">
                <li>Une preuve sociale forte avant la prise de contact.</li>
                <li>Des retours concrets sur le sérieux du suivi et de l'accompagnement.</li>
                <li>Un accès direct à la présence Google de l'entreprise.</li>
              </ul>
              {hasBusinessUrl && (
                <div class="cluster" style="margin-top: 1.5rem;">
                  <Button
                    href={reviewsConfig.googleBusinessUrl}
                    variant="ghost"
                    target="_blank"
                    rel="noreferrer"
                  >
                    Ouvrir Google
                  </Button>
                </div>
              )}
            </div>
          )}
        </div>
      </div>
    </section>
  )
}
