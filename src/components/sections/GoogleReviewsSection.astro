---
import { reviewsConfig } from "../../config/site";
import { testimonials } from "../../data/testimonials";
import Button from "../ui/Button.astro";
import SectionHeading from "../ui/SectionHeading.astro";

const hasBusinessUrl = Boolean(reviewsConfig.googleBusinessUrl.trim());
---

{
  reviewsConfig.enabled && (
    <section class="section surface" style="border-radius: 0; border-inline: 0;">
      <div class="container reviews-grid">
        <div data-reveal="left">
          <SectionHeading
            eyebrow="Avis clients"
            title={reviewsConfig.widgetTitle}
            copy={reviewsConfig.widgetIntro}
          />

          <div class="reviews-stats" data-stats-section>
            <div class="reviews-stat" data-stat-card>
              <strong data-count-up="50" data-count-suffix="+">50+</strong>
              <span>{reviewsConfig.reviewCountLabel}</span>
            </div>
            <div class="reviews-stat" data-stat-card>
              <strong data-count-up="48" data-count-suffix="h">48h</strong>
              <span>rappel commercial annoncé</span>
            </div>
            <div class="reviews-stat" data-stat-card>
              <strong data-count-up="6">6</strong>
              <span>expertises coordonnées pour couvrir le projet</span>
            </div>
          </div>

          <div class="reviews-proof-panel">
            <p class="reviews-proof-copy">
              Une présence locale, un discours rassurant et un accès direct à la prise de contact
              pour convertir plus vite les visiteurs les plus chauds.
            </p>
            {hasBusinessUrl && (
              <div class="cluster" style="margin-top: 1.5rem;">
                <Button
                  href={reviewsConfig.googleBusinessUrl}
                  variant="primary"
                  target="_blank"
                  rel="noreferrer"
                  data-button-sparkle
                >
                  Voir sur Google
                </Button>
              </div>
            )}
          </div>
        </div>

        <div class="reviews-slider-shell" data-reveal="right">
          <div class="testimonial-slider" data-testimonial-slider>
            <div class="testimonial-track" data-testimonial-track>
              {testimonials.map((testimonial, index) => (
                <article
                  class={`testimonial-card ${index === 0 ? "is-active" : ""}`}
                  data-testimonial-slide
                  data-cursor="card"
                  data-cursor-label="Voir →"
                >
                  <div class="testimonial-top">
                    <span class="kicker">{testimonial.eyebrow}</span>
                    <div class="testimonial-stars" aria-label="Note 5 sur 5">
                      {Array.from({ length: 5 }).map(() => (
                        <span>★</span>
                      ))}
                    </div>
                  </div>
                  <h3 class="title-md">{testimonial.title}</h3>
                  <p class="testimonial-quote">“{testimonial.quote}”</p>
                  <div class="testimonial-meta">
                    <div class="testimonial-avatar" aria-hidden="true">
                      <span>{testimonial.initials}</span>
                    </div>
                    <div>
                      <strong>{testimonial.name}</strong>
                      <span>{testimonial.role}</span>
                    </div>
                  </div>
                  <p class="testimonial-highlight">{testimonial.highlight}</p>
                </article>
              ))}
            </div>

            <div class="testimonial-controls">
              <button
                type="button"
                class="testimonial-nav"
                aria-label="Avis précédent"
                data-testimonial-prev
                data-button-sparkle
              >
                ←
              </button>
              <div class="testimonial-dots" role="tablist" aria-label="Sélectionner un avis">
                {testimonials.map((testimonial, index) => (
                  <button
                    type="button"
                    class={`testimonial-dot ${index === 0 ? "is-active" : ""}`}
                    aria-label={`Afficher ${testimonial.title}`}
                    aria-pressed={index === 0 ? "true" : "false"}
                    data-testimonial-dot
                    data-button-sparkle
                  ></button>
                ))}
              </div>
              <button
                type="button"
                class="testimonial-nav"
                aria-label="Avis suivant"
                data-testimonial-next
                data-button-sparkle
              >
                →
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
