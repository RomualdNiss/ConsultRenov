---
import type { Service } from "../../data/services";
import SectionHeading from "../ui/SectionHeading.astro";
import ServiceCard from "../ui/ServiceCard.astro";

interface Props {
  services: Service[];
}

const { services } = Astro.props;
---

<section class="section" id="expertises">
  <div class="container">
    <SectionHeading
      eyebrow="Expertises"
      title="Des expertises complémentaires pour améliorer durablement votre habitat"
      copy="Chaque famille de prestations répond à un besoin concret : mieux isoler, protéger, moderniser et valoriser votre maison."
    />
    <div class="cards-grid">
      {services.map((service, index) => (
        <div data-reveal={index % 2 === 0 ? "left" : "right"}>
          <ServiceCard service={service} />
        </div>
      ))}
    </div>
  </div>
</section>
