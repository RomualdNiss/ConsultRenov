---
import { withBase } from "../../lib/paths";
import Button from "../ui/Button.astro";
import SectionHeading from "../ui/SectionHeading.astro";
---

<section class="section">
  <div class="container split-grid">
    <div data-reveal="left">
      <SectionHeading
        eyebrow="L'entreprise"
        title="Une entreprise de proximité, sérieuse et engagée dans l'amélioration de l'habitat"
        copy="ConsultRenov accompagne les propriétaires qui recherchent un interlocuteur clair pour coordonner un projet de rénovation sur mesure."
      />
      <ul class="bullet-list stack">
        <li>Une lecture simple du projet, sans complexifier les décisions.</li>
        <li>Des solutions pensées pour le confort, la performance et l'image du bien.</li>
        <li>Un accompagnement du premier échange jusqu'au suivi après travaux.</li>
      </ul>
      <div class="cluster" style="margin-top: 1.5rem;">
        <Button href={withBase("a-propos")} variant="primary">Découvrir l'entreprise</Button>
        <Button href={withBase("contact")} variant="ghost">Parler à un conseiller</Button>
      </div>
    </div>

    <div class="highlight-panel" data-reveal="right">
      <div class="stack">
        <span class="eyebrow">Proximité locale</span>
        <h3 class="title-md">Guichainville, Évreux et alentours</h3>
        <p class="text-muted">
          Une présence de proximité pour accompagner les projets situés à Guichainville, à Évreux
          et dans les communes voisines.
        </p>
      </div>
      <div class="contact-strip">
        <span>Rénovation énergétique</span>
        <span>Amélioration de l'habitat</span>
        <span>Accompagnement personnalisé</span>
      </div>
      <div class="accent-panel">
        <h3 class="title-md">Un seul interlocuteur pour avancer simplement</h3>
        <p>
          Étude du besoin, devis gratuit, conseil, planification et suivi : chaque étape est pensée
          pour vous faire avancer sereinement.
        </p>
      </div>
    </div>
  </div>
</section>
