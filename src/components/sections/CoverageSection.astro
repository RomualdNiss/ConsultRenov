---
import { siteConfig } from "../../config/site";
import { withBase } from "../../lib/paths";
import Button from "../ui/Button.astro";
import SectionHeading from "../ui/SectionHeading.astro";
---

<section class="section">
  <div class="container coverage-grid">
    <div data-reveal="left">
      <SectionHeading
        eyebrow="Zone d'intervention"
        title="Nous intervenons à Guichainville, Évreux et dans les communes voisines"
        copy="ConsultRenov accompagne vos projets de rénovation énergétique et d'amélioration de l'habitat avec un suivi de proximité."
      />
      <div class="coverage-list">
        {siteConfig.serviceArea.map((area) => (
          <span>{area}</span>
        ))}
      </div>
      <div class="cluster" style="margin-top: 1.5rem;">
        <Button href={withBase("contact")} variant="primary">Nous parler de votre projet</Button>
      </div>
    </div>

    <div class="highlight-panel" data-reveal="right">
      <h3 class="title-md">Une entreprise locale à votre écoute</h3>
      <p class="text-muted">
        Nous privilégions un accompagnement clair, réactif et personnalisé pour les projets situés
        sur le secteur d'Évreux.
      </p>
      <div class="contact-strip">
        <span>{siteConfig.addressLine}</span>
        <span>{siteConfig.city}</span>
      </div>
    </div>
  </div>
</section>
