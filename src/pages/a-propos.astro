---
import CertificationsSection from "../components/sections/CertificationsSection.astro";
import ContactCtaSection from "../components/sections/ContactCtaSection.astro";
import CoverageSection from "../components/sections/CoverageSection.astro";
import ProcessSection from "../components/sections/ProcessSection.astro";
import Button from "../components/ui/Button.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { withBase } from "../lib/paths";
import BaseLayout from "../layouts/BaseLayout.astro";
import { seoDefaults } from "../data/seo";
---

<BaseLayout title={seoDefaults.aboutTitle} description={seoDefaults.aboutDescription}>
  <section class="page-hero">
    <div class="container split-grid">
      <div class="stack" data-reveal="left">
        <p class="eyebrow">L'entreprise</p>
        <h1 class="title-lg">Une approche humaine et rassurante pour vos projets de rénovation.</h1>
        <p class="lead">
          ConsultRenov vous accompagne avec une relation claire, un suivi personnalisé et des
          solutions pensées pour améliorer durablement le confort de votre habitat.
        </p>
        <div class="cluster">
          <Button href={withBase("contact")} variant="primary">Demander un devis gratuit</Button>
          <Button href={withBase("services")} variant="ghost">Découvrir les services</Button>
        </div>
      </div>
      <div class="highlight-panel" data-reveal="right">
        <h2 class="title-md">Pourquoi faire appel à ConsultRenov ?</h2>
        <ul class="bullet-list stack" style="margin-top: 1rem;">
          <li>Un interlocuteur clair pour votre projet.</li>
          <li>Des solutions adaptées à votre habitat.</li>
          <li>Un accompagnement sérieux du devis au suivi.</li>
          <li>Une entreprise locale, moderne et réactive.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <div data-reveal="left">
        <SectionHeading
          eyebrow="Positionnement"
          title="Spécialiste de la rénovation énergétique et de l'amélioration de l'habitat"
          copy="ConsultRenov accompagne les particuliers dans leurs projets de rénovation avec une approche claire, sur mesure et rassurante."
        />
        <ul class="bullet-list stack">
          <li>Des expertises complémentaires pour traiter votre projet dans sa globalité.</li>
          <li>Une présence locale à Guichainville, Évreux et dans les environs.</li>
          <li>Un devis gratuit et un accompagnement personnalisé.</li>
        </ul>
      </div>
      <div class="accent-panel" data-reveal="right">
        <h3 class="title-md">Le bon équilibre entre savoir-faire et modernité</h3>
        <p>
          ConsultRenov met l'accent sur la qualité d'exécution, la clarté des échanges et un rendu
          soigné à chaque étape du projet.
        </p>
      </div>
    </div>
  </section>

  <CertificationsSection />
  <ProcessSection />
  <CoverageSection />
  <ContactCtaSection />
</BaseLayout>
