---
import CertificationsSection from "../components/sections/CertificationsSection.astro";
import ContactCtaSection from "../components/sections/ContactCtaSection.astro";
import CoverageSection from "../components/sections/CoverageSection.astro";
import ProcessSection from "../components/sections/ProcessSection.astro";
import Button from "../components/ui/Button.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { withBase } from "../lib/paths";
import BaseLayout from "../layouts/BaseLayout.astro";
import { seoDefaults } from "../data/seo";
---

<BaseLayout title={seoDefaults.aboutTitle} description={seoDefaults.aboutDescription}>
  <section class="page-hero">
    <div class="container split-grid">
      <div class="stack" data-reveal="left">
        <p class="eyebrow">L'entreprise</p>
        <h1 class="title-lg">Une approche humaine et rassurante pour vos projets de rénovation.</h1>
        <p class="lead">
          ConsultRenov met en avant un accompagnement personnalisé, une relation client claire et des
          solutions pensées pour améliorer durablement le confort de l'habitat.
        </p>
        <div class="cluster">
          <Button href={withBase("contact")} variant="primary">Demander un devis gratuit</Button>
          <Button href={withBase("services")} variant="ghost">Découvrir les services</Button>
        </div>
      </div>
      <div class="highlight-panel" data-reveal="right">
        <h2 class="title-md">Ce que le site doit faire ressentir</h2>
        <ul class="bullet-list stack" style="margin-top: 1rem;">
          <li>Sérieux et fiabilité dès les premiers écrans.</li>
          <li>Expertise technique sans jargon inutile.</li>
          <li>Proximité client, accompagnement et suivi.</li>
          <li>Image moderne, premium et commerciale.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <div data-reveal="left">
        <SectionHeading
          eyebrow="Positionnement"
          title="Spécialiste de la rénovation énergétique et de l'amélioration de l'habitat"
          copy="Le discours du site est construit autour de projets sur mesure, d'une lecture claire du besoin et d'une exécution suivie dans le temps."
        />
        <ul class="bullet-list stack">
          <li>Des expertises regroupées pour simplifier la lecture d'un projet global.</li>
          <li>Une promesse de proximité pour le secteur de Guichainville et d'Évreux.</li>
          <li>Une expérience de conversion centrée sur le devis gratuit et le rappel rapide.</li>
        </ul>
      </div>
      <div class="accent-panel" data-reveal="right">
        <h3 class="title-md">Le bon équilibre entre artisanat et modernité</h3>
        <p>
          Le rendu du site est propre, lumineux et premium, avec suffisamment d'espace, des CTA
          visibles et des interactions sobres pour inspirer confiance sans effet gadget.
        </p>
      </div>
    </div>
  </section>

  <CertificationsSection />
  <ProcessSection />
  <CoverageSection />
  <ContactCtaSection />
</BaseLayout>
