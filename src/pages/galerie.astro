---
import ContactCtaSection from "../components/sections/ContactCtaSection.astro";
import Button from "../components/ui/Button.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { galleryItems } from "../data/gallery";
import { seoDefaults } from "../data/seo";
import { services } from "../data/services";
import { withBase } from "../lib/paths";
import BaseLayout from "../layouts/BaseLayout.astro";

const galleryFilters = services.map((service) => ({
  slug: service.slug,
  label: service.shortTitle,
  title: service.title,
}));

const serviceLabelBySlug = new Map(services.map((service) => [service.slug, service.shortTitle]));
---

<BaseLayout title={seoDefaults.galleryTitle} description={seoDefaults.galleryDescription}>
  <section class="page-hero">
    <div class="container split-grid">
      <div class="stack" data-reveal="left">
        <p class="eyebrow">Galerie</p>
        <h1 class="title-lg">Des visuels de démonstration pour aider le client à se projeter.</h1>
        <p class="lead">
          Cette galerie regroupe des images de test classées par service pour valider le parcours,
          l'organisation et le rendu visuel avant l'intégration des vraies photos chantier.
        </p>
        <div class="cluster">
          <Button href={withBase("services")} variant="ghost" data-button-sparkle>
            Voir les services
          </Button>
          <Button href={withBase("contact")} variant="primary" data-button-sparkle data-cursor-cta>
            Demander un devis gratuit
          </Button>
        </div>
      </div>
      <div class="highlight-panel stack" data-reveal="right">
        <h2 class="title-md">Galerie statique, simple à faire évoluer</h2>
        <p class="text-muted">
          Les visuels affichés ici sont des exemples issus du web, stockés localement dans le projet
          pour les tests. Ils pourront être remplacés plus tard sans changer la structure de la page.
        </p>
        <ul class="bullet-list stack">
          <li>Filtrage multi-sélection par services.</li>
          <li>Ajout ou retrait d'images sans base de données.</li>
          <li>Compatible mobile, tablette et desktop.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Inspirations"
        title="Filtrer la galerie selon les expertises à mettre en avant"
        copy="Sélectionnez un ou plusieurs services pour ne garder que les visuels pertinents. Les images restent volontairement démonstratives et non contractuelles."
      />

      <div class="gallery-shell surface" data-gallery-root>
        <div class="gallery-toolbar">
          <div class="gallery-filter-list" role="group" aria-label="Filtrer la galerie par service">
            <button
              type="button"
              class="gallery-filter is-active"
              data-filter-reset
              aria-pressed="true"
              data-button-sparkle
            >
              Tous
            </button>
            {galleryFilters.map((filter) => (
              <button
                type="button"
                class="gallery-filter"
                data-service-filter={filter.slug}
                aria-pressed="false"
                title={filter.title}
                data-button-sparkle
              >
                {filter.label}
              </button>
            ))}
          </div>
          <p class="gallery-results text-muted" data-gallery-count>
            {galleryItems.length} visuels affichés
          </p>
        </div>

        <div class="gallery-grid">
          {galleryItems.map((item, index) => (
            <article
              class="gallery-card"
              data-gallery-card
              data-services={item.services.join(",")}
              data-reveal={index % 2 === 0 ? "left" : "right"}
              style={`--reveal-delay:${index * 80}ms;`}
            >
              <div class="gallery-media" data-gallery-media data-cursor="card" data-cursor-label="Voir →">
                <div class="gallery-skeleton" aria-hidden="true"></div>
                <img
                  src={withBase(item.image)}
                  alt={item.alt}
                  loading={index < 4 ? "eager" : "lazy"}
                  width="1600"
                  height="1200"
                  data-gallery-image
                />
                <div class="gallery-overlay" aria-hidden="true">
                  <span class="gallery-overlay-tag">Projet inspirant</span>
                  <span class="gallery-overlay-copy">Voir le détail</span>
                </div>
              </div>
              <div class="gallery-card-body">
                <div class="gallery-card-top">
                  <span class="kicker">Visuel de test</span>
                </div>
                <h2 class="title-md">{item.title}</h2>
                <p class="text-muted">{item.description}</p>
                <div class="gallery-tag-list" aria-label="Services associés">
                  {item.services.map((slug) => (
                    <span class="gallery-tag">{serviceLabelBySlug.get(slug) ?? slug}</span>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>

        <div class="gallery-empty accent-panel" data-gallery-empty hidden>
          <h2 class="title-md">Aucun visuel ne correspond à cette combinaison.</h2>
          <p>
            Désactivez un filtre ou revenez à <strong>Tous</strong> pour afficher l'ensemble des
            images de démonstration.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ContactCtaSection />

  <script is:inline>
    const galleryRoot = document.querySelector("[data-gallery-root]");

    if (galleryRoot) {
      const resetButton = galleryRoot.querySelector("[data-filter-reset]");
      const filterButtons = Array.from(galleryRoot.querySelectorAll("[data-service-filter]"));
      const cards = Array.from(galleryRoot.querySelectorAll("[data-gallery-card]"));
      const counter = galleryRoot.querySelector("[data-gallery-count]");
      const emptyState = galleryRoot.querySelector("[data-gallery-empty]");
      const activeFilters = new Set();

      const updateCounter = (visibleCount) => {
        if (!counter) return;
        const suffix = visibleCount > 1 ? "s" : "";
        counter.textContent = `${visibleCount} visuel${suffix} affiché${suffix}`;
      };

      const syncFilterButtons = () => {
        const hasFilters = activeFilters.size > 0;

        if (resetButton) {
          resetButton.classList.toggle("is-active", !hasFilters);
          resetButton.setAttribute("aria-pressed", String(!hasFilters));
        }

        filterButtons.forEach((button) => {
          const serviceSlug = button.getAttribute("data-service-filter");
          const isActive = serviceSlug ? activeFilters.has(serviceSlug) : false;
          button.classList.toggle("is-active", isActive);
          button.setAttribute("aria-pressed", String(isActive));
        });
      };

      const syncCards = () => {
        let visibleCount = 0;

        cards.forEach((card) => {
          const serviceList =
            card.getAttribute("data-services")?.split(",").filter(Boolean) ?? [];
          const isVisible =
            activeFilters.size === 0 ||
            serviceList.some((serviceSlug) => activeFilters.has(serviceSlug));

          card.toggleAttribute("hidden", !isVisible);
          card.classList.toggle("is-hidden", !isVisible);

          if (isVisible) {
            visibleCount += 1;
          }
        });

        updateCounter(visibleCount);

        if (emptyState) {
          emptyState.hidden = visibleCount !== 0;
        }
      };

      syncFilterButtons();
      syncCards();

      resetButton?.addEventListener("click", () => {
        activeFilters.clear();
        syncFilterButtons();
        syncCards();
      });

      filterButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const serviceSlug = button.getAttribute("data-service-filter");
          if (!serviceSlug) return;

          if (activeFilters.has(serviceSlug)) {
            activeFilters.delete(serviceSlug);
          } else {
            activeFilters.add(serviceSlug);
          }

          syncFilterButtons();
          syncCards();
        });
      });
    }
  </script>
</BaseLayout>
