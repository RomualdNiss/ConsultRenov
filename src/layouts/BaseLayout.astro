---
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";
import SeoHead from "../components/layout/SeoHead.astro";
import { siteConfig } from "../config/site";
import { withBase } from "../lib/paths";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  structuredData?: Record<string, unknown>[] | Record<string, unknown>;
}

const { title, description, image, noIndex = false, structuredData = [] } = Astro.props;
const canonical = Astro.url.href;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: siteConfig.name,
  description: siteConfig.description,
  url: siteConfig.siteUrl,
  telephone: siteConfig.phone,
  email: siteConfig.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: siteConfig.addressLine,
    postalCode: siteConfig.postalCode,
    addressLocality: siteConfig.city,
    addressCountry: "FR",
  },
  areaServed: siteConfig.serviceArea,
};

const schemas = Array.isArray(structuredData) ? structuredData : [structuredData];
---

<!doctype html>
<html lang="fr">
  <head>
    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      noIndex={noIndex}
      structuredData={[localBusinessSchema, ...schemas]}
    />
  </head>
  <body data-page={Astro.url.pathname}>
    <div class="scroll-progress" aria-hidden="true" data-scroll-progress></div>
    <div id="cursor-ring" aria-hidden="true">
      <span class="cursor-label" data-cursor-label>Voir →</span>
    </div>
    <div id="cursor-dot" aria-hidden="true"></div>
    <div class="social-proof-badge" aria-live="polite" data-social-proof>
      <span class="social-proof-icon" aria-hidden="true">✓</span>
      <span>{siteConfig.socialProofBadge}</span>
    </div>
    <a
      class="floating-whatsapp"
      href={siteConfig.whatsappHref}
      target="_blank"
      rel="noreferrer"
      aria-label="Contacter ConsultRenov sur WhatsApp"
      data-button-sparkle
      data-cursor-cta
    >
      <svg aria-hidden="true" viewBox="0 0 24 24" width="24" height="24" fill="none">
        <path
          d="M19.2 4.8A9.4 9.4 0 0 0 4.1 16.1L3 21l5-1a9.4 9.4 0 0 0 11.2-15.2Z"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <path
          d="M9 8.8c.2-.6.4-.7.7-.7h.6c.2 0 .5.1.6.5l.8 2c.1.3 0 .5-.1.7l-.5.6c-.1.1-.1.3 0 .5.4.7 1.1 1.4 1.8 1.8.2.1.4.1.5 0l.6-.5c.2-.1.4-.2.7-.1l2 .8c.4.1.5.4.5.6v.6c0 .3-.1.5-.7.7-.4.1-1 .2-1.7 0a8.2 8.2 0 0 1-5.2-5.2c-.2-.7-.1-1.3 0-1.7Z"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
      <span class="floating-whatsapp-label">WhatsApp</span>
    </a>
    <div class="mobile-sticky-cta">
      <a href={withBase("contact")} data-button-sparkle data-cursor-cta>
        {siteConfig.mobileStickyCtaLabel}
      </a>
    </div>
    <div class="site-shell">
      <a class="sr-only" href="#main-content">Aller au contenu principal</a>
      <Header />
      <main id="main-content">
        <slot />
      </main>
      <Footer />
    </div>

    <script>
      import "../scripts/site-interactions.ts";
    </script>
  </body>
</html>
